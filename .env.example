# A股 AI 量化分析顾问 - 环境变量模板
# 复制此文件为 .env 并填入实际值

# ============ Anthropic Claude API ============
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# 自定义 API 端点（可选，留空则使用官方默认地址）
ANTHROPIC_BASE_URL=
CLAUDE_MODEL=claude-sonnet-4-20250514
MAX_TOKENS=4096

# ============ 分析参数 ============
# K线数据默认周期（日: daily, 周: weekly）
DEFAULT_KLINE_PERIOD=daily
# 财联社快讯拉取条数
NEWS_FETCH_LIMIT=50
# 历史推荐记录查询条数
HISTORY_REPORT_LIMIT=10
